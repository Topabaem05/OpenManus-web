FROM python:3.12-slim

WORKDIR /app/OpenManus

# System dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    git curl build-essential libffi-dev \
    && rm -rf /var/lib/apt/lists/*

# Install uv for fast pip
RUN pip install --no-cache-dir uv

# Copy requirements and install
COPY requirements.txt .
RUN uv pip install --system -r requirements.txt
RUN pip install --no-cache-dir microsandbox

# Install playwright browsers
RUN playwright install chromium --with-deps 2>/dev/null || true

# Copy source
COPY . .

# Build frontend
RUN apt-get update && apt-get install -y --no-install-recommends nodejs npm \
    && cd web && npm install && npm run build \
    && rm -rf node_modules \
    && rm -rf /var/lib/apt/lists/*

# Expose API port
EXPOSE 9000

# Run the FastAPI server, serving built frontend + API
CMD ["python", "-m", "uvicorn", "app.web.server:app", "--host", "0.0.0.0", "--port", "9000"]
